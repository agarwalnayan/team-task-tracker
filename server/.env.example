# Database
MONGO_URI=mongodb://localhost:27017/team-task-tracker

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=7d

# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash-preview

# When Mock AI is true, the server will use mock AI responses instead of calling the Gemini API
USE_MOCK_AI=true

# Server
PORT=5000
NODE_ENV=development

# CORS (for development)
FRONTEND_URL=http://localhost:5173


# Hunter for email verification
HUNTER_API_KEY=hunter-api-key-for-email-verification

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5


